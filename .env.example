# =============================================================================
# FinRPA Enterprise -- Environment Configuration
# Copy this file to .env and fill in your values
# =============================================================================

# -----------------------------------------------------------------------------
# General
# -----------------------------------------------------------------------------
ENV=local
LOG_LEVEL=INFO
PORT=8000

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
DATABASE_STRING=postgresql+psycopg://skyvern:skyvern@localhost:5432/skyvern

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# MinIO (Private Object Storage)
# -----------------------------------------------------------------------------
MINIO_ENDPOINT=localhost:9000
MINIO_ROOT_USER=finrpa
MINIO_ROOT_PASSWORD=finrpa_secret_2024
MINIO_BUCKET_PREFIX=finrpa-audit
MINIO_USE_SSL=false

# -----------------------------------------------------------------------------
# LLM Provider
# -----------------------------------------------------------------------------
# --- OpenAI ---
ENABLE_OPENAI=false
OPENAI_API_KEY=
# LLM_KEY=OPENAI_GPT4O

# --- Anthropic ---
ENABLE_ANTHROPIC=false
ANTHROPIC_API_KEY=
# LLM_KEY=ANTHROPIC_CLAUDE3.5_SONNET

# --- Azure OpenAI ---
ENABLE_AZURE=false
AZURE_DEPLOYMENT=
AZURE_API_KEY=
AZURE_API_BASE=
AZURE_API_VERSION=

# --- Primary & Secondary model keys ---
LLM_KEY=
SECONDARY_LLM_KEY=

# -----------------------------------------------------------------------------
# Browser Configuration
# -----------------------------------------------------------------------------
BROWSER_TYPE=chromium-headful
MAX_SCRAPING_RETRIES=0
VIDEO_PATH=./videos
BROWSER_ACTION_TIMEOUT_MS=5000
MAX_STEPS_PER_RUN=50

# -----------------------------------------------------------------------------
# Enterprise: JWT Authentication
# -----------------------------------------------------------------------------
JWT_SECRET_KEY=CHANGE_ME_TO_A_RANDOM_64_CHAR_STRING
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# -----------------------------------------------------------------------------
# Enterprise: Approval Engine
# -----------------------------------------------------------------------------
APPROVAL_TIMEOUT_HIGH_SECONDS=1800
APPROVAL_TIMEOUT_CRITICAL_SECONDS=3600

# -----------------------------------------------------------------------------
# Enterprise: Notification Webhooks
# -----------------------------------------------------------------------------
WECHAT_WEBHOOK_URL=
DINGTALK_WEBHOOK_URL=
DINGTALK_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Enterprise: Frontend URL (for approval links in notifications)
# -----------------------------------------------------------------------------
FRONTEND_BASE_URL=http://localhost:8080

# -----------------------------------------------------------------------------
# Enterprise: Encryption (for sensitive workflow parameters)
# -----------------------------------------------------------------------------
FERNET_ENCRYPTION_KEY=

# -----------------------------------------------------------------------------
# Analytics (optional)
# -----------------------------------------------------------------------------
ANALYTICS_ID=anonymous
